rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Room Rules ---

    function isValidRoom(data) {
      return data.status in ['lobby', 'playing', 'results'] &&
             data.grid is list &&
             data.createdBy is string &&
             data.createdAt is timestamp;
    }

    match /rooms/{roomId} {
      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(incoming()) && incoming().createdBy == request.auth.uid;
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (
        // Only creator can change status or start game
        (existing().createdBy == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'grid', 'level'])) ||
        // Syncing grid state (blocks destroyed)
        (incoming().diff(existing()).affectedKeys().hasOnly(['grid']))
      ) && isValidRoom(incoming());
    }

    // --- Player Rules ---

    function isValidPlayer(data) {
      return data.uid is string && 
             data.uid == request.auth.uid &&
             data.pos.x is number && 
             data.pos.y is number &&
             data.isAlive is bool &&
             data.displayName is string &&
             data.color is string;
    }

    match /rooms/{roomId}/players/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && uid == request.auth.uid && isValidPlayer(incoming());
      allow delete: if isSignedIn() && uid == request.auth.uid;
    }

    // --- Bomb Rules ---

    function isValidBomb(data) {
      return data.pos.x is number && 
             data.pos.y is number &&
             data.range is number &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    match /rooms/{roomId}/bombs/{bombId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(bombId) && isValidBomb(incoming());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid)));
    }
  }
}
